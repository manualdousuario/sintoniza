{
    "require": {
        "php": "^8.0",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-tidy": "*",
        "gregwar/captcha": "^1.3",
        "guzzlehttp/guzzle": "^7.10",
        "guzzlehttp/psr7": "^2.8",
        "jessedp/php-timezones": "^0.2.3",
        "josantonius/session": "^2.0",
        "laminas/laminas-diactoros": "^3.8",
        "laminas/laminas-httphandlerrunner": "^2.13",
        "league/climate": "^3.10",
        "league/container": "^4.2",
        "league/plates": "^3.6",
        "league/route": "^6.2",
        "league/uri": "^7.5",
        "middlewares/whoops": "^2.1",
        "monolog/monolog": "^3.9",
        "phpmailer/phpmailer": "^6.11",
        "predis/predis": "^3.4",
        "robmorgan/phinx": "^0.16",
        "sergeytsalkov/meekrodb": "^3.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Sintoniza\\": "src/"
        },
        "files": [
            "src/Library/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Sintoniza\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
