#!/usr/bin/env php
<?php

declare(strict_types=1);

if (PHP_SAPI !== 'cli') {
    exit(1);
}

ini_set('memory_limit', '256M');
gc_enable();

require_once __DIR__ . '/../config/config.php';

use League\CLImate\CLImate;
use Sintoniza\Cli\UpdateFeeds;
use Sintoniza\Library\Container;
use Sintoniza\Service\FeedService;

$container = Container::getInstance();
$runner    = new UpdateFeeds(
    $container->get(FeedService::class),
    new CLImate()
);

$maxFeeds = null;
foreach (array_slice($argv, 1) as $arg) {
    if (preg_match('/^--max-feeds=(\d+)$/', $arg, $m)) {
        $maxFeeds = (int) $m[1];
    }
}

$runner->run($maxFeeds);
